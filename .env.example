# Cronhaus Inbox — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# OpenRouter API key (for AI model routing)
OPENROUTER_API_KEY=

# Vercel AI Gateway (if using Vercel AI Gateway proxy)
# AI_GATEWAY_URL=
# AI_GATEWAY_API_KEY=

# Next.js public base URL (optional, for redirects/callbacks)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
